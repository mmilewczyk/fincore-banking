{
  "type": "record",
  "name": "AccountDebitedEvent",
  "namespace": "com.matcodem.fincore.account.avro",
  "doc": "Published when funds are debited. Consumed by Analytics, Notification Service.",
  "fields": [
    {
      "name": "eventId",
      "type": "string"
    },
    {
      "name": "occurredAt",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      }
    },
    {
      "name": "accountId",
      "type": "string"
    },
    {
      "name": "amount",
      "type": {
        "type": "bytes",
        "logicalType": "decimal",
        "precision": 19,
        "scale": 4
      }
    },
    {
      "name": "currency",
      "type": "AccountCurrency"
    },
    {
      "name": "balanceAfter",
      "type": {
        "type": "bytes",
        "logicalType": "decimal",
        "precision": 19,
        "scale": 4
      },
      "doc": "Balance after debit - used for statement generation and real-time balance push"
    },
    {
      "name": "reference",
      "type": "string",
      "doc": "paymentId or other correlation reference"
    },
    {
      "name": "schemaVersion",
      "type": "int",
      "default": 1
    }
  ]
}